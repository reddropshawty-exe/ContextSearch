@startuml
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
hide empty members

' ============================================================
' 1) Domain layer: сущности и контракты
' ============================================================
package "domain.entities" {
  class Document {
    +id: str
    +path: str?
    +title: str?
    +mime_type: str?
    +content: str
    +content_hash: str?
    +modified_at: datetime?
    +metadata: dict
  }

  class Chunk {
    +id: str
    +document_id: str
    +text: str
    +start: int?
    +end: int?
    +text_hash: str?
    +metadata: dict
  }

  class Query {
    +text: str
    +metadata: dict
  }

  class RetrievalResult {
    +document_id: str
    +score: float
    +chunk: Chunk?
    +chunk_text_preview: str?
    +document: Document?
    +metadata: dict
  }

  class EmbeddingSpec {
    +id: str
    +model_name: str
    +dimension: int
    +metric: str
    +normalize: bool
    +level: str
    +params: dict
  }
}

package "domain.interfaces" {
  interface TextExtractor {
    +extract(source: bytes|str): str
  }

  interface ChunkSplitter {
    +split(document: Document): list<Chunk>
  }

  interface Embedder {
    +model_id: str
    +dimension: int
    +embed_texts(texts: Sequence<str>): list<list<float>>
    +embed_query(query: Query): list<float>
  }

  interface EmbeddingStore {
    +add(spec: EmbeddingSpec, object_type: str, object_ids: Sequence<str>, embeddings: Sequence<Sequence<float>>): None
    +search(spec: EmbeddingSpec, query_embedding: Sequence<float>, top_k: int = 5): list<tuple<int,float>>
  }

  interface DocumentRepository {
    +add(document: Document): None
    +list(): list<Document>
    +get(document_id: str): Document?
  }

  interface ChunkRepository {
    +add(chunk: Chunk): str
    +list(): list<Chunk>
    +get(chunk_id: str): Chunk?
  }

  interface EmbeddingSpecRepository {
    +upsert(spec: EmbeddingSpec): None
    +list(): list<EmbeddingSpec>
    +get(spec_id: str): EmbeddingSpec?
  }

  interface EmbeddingRecordRepository {
    +add_records(spec_id: str, object_type: str, object_ids: Sequence<str>, ann_ids: Sequence<int>): None
    +find_object_ids(spec_id: str, ann_ids: Sequence<int>): list<str>
    +list_object_ids(spec_id: str, object_type: str): list<str>
  }

  interface QueryRewriter {
    +rewrite(query: Query): list<Query>
  }

  interface Reranker {
    +rerank(query: Query, results: Iterable<RetrievalResult>): list<RetrievalResult>
  }
}

Document "1" o-- "*" Chunk
RetrievalResult o-- Query
RetrievalResult o-- Chunk
RetrievalResult o-- Document

newpage
' ============================================================
' 2) Application layer: use-cases и evaluation
' ============================================================
package "application.use_cases" {
  class ingest_documents <<use-case>> {
    +ingest_documents(sources, extractor, splitter, embedders, embedding_store, document_repository, chunk_repository, embedding_specs, bm25_index): list<Document>
    -_index_embeddings(embedders, embedding_store, embedding_specs, document, chunks): None
  }

  class search <<use-case>> {
    +search(query_text, embedders, embedding_store, document_repository, chunk_repository, embedding_record_repository, embedding_specs, query_rewriter, reranker, bm25_index, top_k, use_bm25, ranking_mode): list<RetrievalResult>
    -_ensure_in_memory_index(...): None
    -_rrf_scores(*rankings, k): dict<str,float>
  }
}

package "application.evaluation.models" {
  class RelevanceLabel {
    +document_id: str
    +grade: int
    +chunk_id: str?
  }

  class TestCase {
    +id: str
    +query_text: str
    +source: str
    +relevance_labels: list<RelevanceLabel>
    +metadata: dict<str,str>
  }

  class TestSuite {
    +id: str
    +name: str
    +description: str
    +document_ids: list<str>
    +test_cases: list<TestCase>
  }

  class ExperimentConfig {
    +id: str
    +embedding_spec_id: str
    +store_type: str
    +use_bm25: bool
    +ranking_mode: str
    +query_rewriter: str
    +top_k: int
    +rrf_k: int
    +metadata: dict<str,str>
  }

  class CaseRunResult {
    +test_case_id: str
    +ranked_document_ids: list<str>
    +ranked_chunk_ids: list<str>
    +scores: list<float>
    +score_breakdown: list<dict>
    +metrics: dict<str,float>
  }

  class ExperimentRun {
    +id: str
    +test_suite_id: str
    +experiment_config_id: str
    +created_at: datetime
    +case_results: list<CaseRunResult>
    +aggregate_metrics: dict<str,float>
  }
}

package "application.evaluation.service" {
  class EvaluationService <<module>> {
    +create_test_suite(name, description): TestSuite
    +create_test_case(query_text, relevant_document_ids, source, metadata, graded_relevance): TestCase
    +create_experiment_config(...): ExperimentConfig
    +run_and_save_experiment(suite, config, container, repository): ExperimentRun
  }
}

ingest_documents ..> TextExtractor
ingest_documents ..> ChunkSplitter
ingest_documents ..> Embedder
ingest_documents ..> EmbeddingStore
ingest_documents ..> DocumentRepository
ingest_documents ..> ChunkRepository
ingest_documents ..> EmbeddingSpec

search ..> Embedder
search ..> EmbeddingStore
search ..> EmbeddingRecordRepository
search ..> DocumentRepository
search ..> ChunkRepository
search ..> QueryRewriter
search ..> Reranker

TestSuite "1" o-- "*" TestCase
TestCase "1" o-- "*" RelevanceLabel
ExperimentRun "1" o-- "*" CaseRunResult
EvaluationService ..> search

