' ============================================================
' 3) Infrastructure layer: реализации и DI-контейнер
' ============================================================
package "infrastructure.config" {
  class ContainerConfig {
    +extractor: ExtractorName
    +embedder: EmbedderName
    +rewriter: RewriterName
    +embedding_store: EmbeddingStoreName
    +profile: ProfileName
    +data_root: str
    +device: str
    +normalize_embeddings: bool
    +embeddinggemma_model: str
    +local_rewriter_model: str
    +models_dir: str?
    +safe_mode: bool
    +embedder_models: tuple<EmbedderName>
  }

  class Container {
    +extractor: TextExtractor
    +splitter: ChunkSplitter
    +embedder: Embedder
    +embedders: dict<EmbedderName, Embedder>
    +embedding_store: EmbeddingStore
    +document_repository: DocumentRepository
    +chunk_repository: ChunkRepository
    +embedding_spec_repository: EmbeddingSpecRepository
    +embedding_record_repository: EmbeddingRecordRepository
    +query_rewriter: QueryRewriter
    +reranker: Reranker
    +embedding_specs: list<EmbeddingSpec>
    +bm25_index: BM25Index
    +evaluation_repository: SqliteEvaluationRepository?
  }

  class ConfigFactory <<module>> {
    +build_default_container(config: ContainerConfig?): Container
    -_build_embedders(config): dict
    -_build_embedding_store(config, record_repository, db_path, index_root): EmbeddingStore
    -_build_rewriter(config): QueryRewriter
  }
}

package "infrastructure.implementations" {
  class PdfExtractor { +extract(source): str }
  class DocxExtractor { +extract(source): str }
  class HtmlExtractor { +extract(source): str }
  class PlainTextExtractor { +extract(source): str }

  class FixedWindowSplitter { +split(document): list<Chunk> }

  class MiniLMEmbedder {
    +model_id: str
    +dimension: int
    +embed_texts(texts): list<list<float>>
    +embed_query(query): list<float>
  }

  class MeanWordHashEmbedder {
    +model_id: str
    +dimension: int
    +embed_texts(texts): list<list<float>>
    +embed_query(query): list<float>
  }

  class CharacterNgramEmbedder {
    +model_id: str
    +dimension: int
    +embed_texts(texts): list<list<float>>
    +embed_query(query): list<float>
  }

  class SentenceTransformersEmbedder {
    +model_id: str
    +dimension: int
    +embed_texts(texts): list<list<float>>
    +embed_query(query): list<float>
  }

  class InMemoryEmbeddingStore { +add(...): None +search(...): list +has_entries(spec_id): bool }
  class SqliteEmbeddingStore { +add(...): None +search(...): list }
  class HnswEmbeddingStore { +add(...): None +search(...): list }

  class SqliteDocumentRepository { +add(document): None +list(): list<Document> +get(document_id): Document? }
  class SqliteChunkRepository { +add(chunk): str +list(): list<Chunk> +get(chunk_id): Chunk? }
  class SqliteEmbeddingSpecRepository { +upsert(spec): None +list(): list<EmbeddingSpec> +get(spec_id): EmbeddingSpec? }
  class SqliteEmbeddingRecordRepository {
    +add_records(spec_id, object_type, object_ids, ann_ids): None
    +find_object_ids(spec_id, ann_ids): list<str>
    +list_object_ids(spec_id, object_type): list<str>
  }
  class SqliteEvaluationRepository {
    +upsert_suite(suite): None
    +upsert_config(config): None
    +save_run(run): None
    +list_runs(): list<ExperimentRun>
    +list_suites(): list<TestSuite>
  }

  class SimpleQueryRewriter { +rewrite(query): list<Query> }
  class LLMQueryRewriter { +rewrite(query): list<Query> }
  class SimpleReranker { +rerank(query, results): list<RetrievalResult> }
}

TextExtractor <|.. PdfExtractor
TextExtractor <|.. DocxExtractor
TextExtractor <|.. HtmlExtractor
TextExtractor <|.. PlainTextExtractor

ChunkSplitter <|.. FixedWindowSplitter

Embedder <|.. MiniLMEmbedder
Embedder <|.. MeanWordHashEmbedder
Embedder <|.. CharacterNgramEmbedder
Embedder <|.. SentenceTransformersEmbedder

EmbeddingStore <|.. InMemoryEmbeddingStore
EmbeddingStore <|.. SqliteEmbeddingStore
EmbeddingStore <|.. HnswEmbeddingStore

DocumentRepository <|.. SqliteDocumentRepository
ChunkRepository <|.. SqliteChunkRepository
EmbeddingSpecRepository <|.. SqliteEmbeddingSpecRepository
EmbeddingRecordRepository <|.. SqliteEmbeddingRecordRepository

QueryRewriter <|.. SimpleQueryRewriter
QueryRewriter <|.. LLMQueryRewriter
Reranker <|.. SimpleReranker

